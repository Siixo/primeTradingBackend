# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=ptdb

# Application Configuration
HOST=0.0.0.0
PORT=8080
JWT_SIGNING_KEY=your_random_32char_base64_string_here
COOKIE_SECURE=false

# CORS: comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3100,http://127.0.0.1:3100

# Postgres SSL mode (disable for local docker, require in production)
DB_SSLMODE=disable

# API Keys (Free/Paid Providers)
GOLD_PRICEZ_API_KEY=
ALPHA_VANTAGE_API_KEY=
YAHOO_APP_ID=
YAHOO_CONSUMER_KEY=
YAHOO_CONSUMER_SECRET=

# Optional: Other metal price keys if used
METALS_DEV_API_KEY=
TWELVE_DATA_API_KEY=
API_NINJA_API_KEY=
